  .search-box {\n            width: 90%;\n            max-width: 584px;\n            position: relative;\n        }\n        .search-box input {\n            width: 100%;\n            padding: 12px 45px 12px 45px;\n            font-size: 16px;\n            border: 1px solid #dfe1e5;\n            border-radius: 24px;\n            outline: none;\n            transition: box-shadow 0.2s;\n        }\n        .search-box input:hover,\n        .search-box input:focus {\n            box-shadow: 0 1px 6px rgba(32,33,36,0.28);\n            border-color: rgba(223,225,229,0);\n        }\n        .search-icon {\n            position: absolute;\n            left: 15px;\n            top: 50%;\n            transform: translateY(-50%);\n            color: #9aa0a6;\n        }\n        .mic-icon {\n            position: absolute;\n            right: 15px;\n            top: 50%;\n            transform: translateY(-50%);\n            cursor: pointer;\n        }\n        .buttons {\n            margin-top: 25px;\n            display: flex;\n            gap: 12px;\n        }\n        .buttons button {\n            background: #f8f9fa;\n            border: 1px solid #f8f9fa;\n            border-radius: 4px;\n            color: #3c4043;\n            font-size: 14px;\n            padding: 10px 20px;\n            cursor: pointer;\n        }\n        .buttons button:hover {\n            border: 1px solid #dadce0;\n            box-shadow: 0 1px 1px rgba(0,0,0,0.1);\n            color: #202124;\n        }\n        .footer {\n            background: #f2f2f2;\n            color: #70757a;\n            font-size: 13px;\n        }\n        .footer-top {\n            padding: 12px 30px;\n            border-bottom: 1px solid #dadce0;\n        }\n        .footer-bottom {\n            padding: 12px 30px;\n            display: flex;\n            justify-content: space-between;\n            flex-wrap: wrap;\n        }\n        .footer-bottom a {\n            color: #70757a;\n            text-decoration: none;\n            margin: 0 10px;\n            cursor: pointer;\n        }\n        .footer-bottom a:hover {\n            text-decoration: underline;\n        }\n        .results-container {\n            width: 90%;\n            max-width: 584px;\n            margin-top: 20px;\n            display: none;\n        }\n        .result-item {\n            padding: 12px 0;\n            border-bottom: 1px solid #eee;\n        }\n        .result-item .url {\n            color: #202124;\n            font-size: 12px;\n            margin-bottom: 4px;\n        }\n        .result-item .title {\n            color: #1a0dab;\n            font-size: 18px;\n            cursor: pointer;\n        }\n        .result-item .title:hover {\n            text-decoration: underline;\n        }\n        .result-item .desc {\n            color: #545454;\n            font-size: 13px;\n            margin-top: 4px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"navbar\">\n        <a>Gmail</a>\n        <a>Hình ảnh</a>\n        <a id=\"apps-btn\">☰</a>\n        <a id=\"avatar-btn\">👤</a>\n    </div>\n    <div class=\"main\">\n        <div class=\"logo\">\n            <span>H</span><span>i</span><span>e</span><span>u</span><span>b</span><span>ot</span>\n        </div>\n        <div class=\"search-box\">\n            <span class=\"search-icon\">🔍</span>\n            <input type=\"text\" id=\"search-input\" placeholder=\"Tìm kiếm trên Hieudabot hoặc gõ URL\">\n            <span class=\"mic-icon\">🎤</span>\n        </div>\n        <div class=\"buttons\">\n            <button onclick=\"search()\">Tìm kiếm trên Hieudabot</button>\n            <button>Xem chú mèo may mắn</button>\n        </div>\n        <div class=\"results-container\" id=\"results\"></div>\n    </div>\n    <div class=\"footer\">\n        <div class=\"footer-top\">Việt Nam</div>\n        <div class=\"footer-bottom\">\n            <div>\n                <a>Giới thiệu</a>\n                <a>Quảng cáo</a>\n                <a>Do